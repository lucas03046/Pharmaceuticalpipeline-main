# Local frontend/backend configuration for the pharma pipeline dashboard
# Copy this file to `.env` if you want to override defaults.

# Frontend talks to the local Python backend here.
VITE_API_BASE_URL=http://127.0.0.1:8000

# Optional override for the local SQLite database path used by the backend.
# PPP_DATABASE_PATH=C:\path\to\pharmapipeline.db
